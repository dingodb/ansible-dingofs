kind: dingofs
global:
  container_image: {{ dingofs_container_image }}
  data_dir: {{ dingofs_data_dir }}
  log_dir: {{ dingofs_log_dir }}
  raft_dir: {{ dingofs_raft_dir }}
  default_replica_num: {{ dingofs_default_replica_num }}
  source_core_dir: {{ dingofs_core_dir }}
  target_core_dir: {{ dingofs_core_dir }}
  cluster_id: {{ dingofs_cluster_id }}
  variable:
    home: {{ dingofs_home_tmp }}
{% for host in groups['meta_servers'] %}
    machine{{ loop.index }}: {{ host }}
{% endfor %}

coordinator_services:
  config:
    container_image: {{ dingofs_store_image }}
    server.port: {{ coordinator_server_port }}
    raft.port: {{ coordinator_raft_port }}
  deploy:
{% for host in groups['meta_servers'] %}
    - host: ${machine{{ loop.index }}}
{% endfor %}

store_services:
  config:
    container_image: {{ dingofs_store_image }}
    server.port: {{ store_server_port }}
    raft.port: {{ store_raft_port }}
    block_cache_size: {{ store_block_cache_size }}
    gflags.dingo_log_switch_txn_detail: {{ store_txn_detail_log | lower }}
    mount.volumes: {{ store_mount_volumes }}
  deploy:
{% for host in groups['meta_servers'] %}
    - host: ${machine{{ loop.index }}}
{% endfor %}

mds_services:
  config:
    server.port: {{ mds_base_port }}${service_replica_sequence}
    mds_compact_chunk_enable: {{ mds_compact_chunk_enable | lower }}
  deploy:
{% for host in groups['meta_servers'] %}
    - host: ${machine{{ loop.index }}}
      replicas: {{ mds_replicas }}
{% endfor %}

executor_services:
  config:
    container_image: {{ dingofs_executor_image }}
    port: {{ executor_port }}
    mysqlPort: {{ executor_mysql_port }}
    java.Xms: {{ executor_java_xms }}
    java.Xmx: {{ executor_java_xmx }}
    java.SoftMaxHeapSize: {{ executor_java_soft_max_heap }}
    java.MaxDirectMemorySize: {{ executor_java_max_direct_memory }}
  deploy:
    - host: ${machine1}
